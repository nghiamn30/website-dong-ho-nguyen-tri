generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Permission {
  code  String           @id @db.VarChar(80)
  name  String           @db.VarChar(160)
  roles RolePermission[]

  @@map("permissions")
}

model Role {
  code        String           @id @db.VarChar(40)
  name        String           @db.VarChar(160)
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  employeeCode String     @unique @map("employee_code") @db.VarChar(40)
  name         String     @db.VarChar(160)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  personId     String?    @map("person_id") @db.Uuid
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  roles        UserRole[]

  person              Person?              @relation("PersonUserAccounts", fields: [personId], references: [id], onDelete: SetNull)
  notifications       Notification[]       @relation("UserNotifications")
  notificationSetting NotificationSetting? @relation("UserNotificationSetting")
  posts               Post[]               @relation("UserPosts")
  albums              Album[]              @relation("UserAlbums")
  media               Media[]              @relation("UserMedia")
  pages               PageContent[]        @relation("UserPages")
  branchScopedRoles   BranchScopedRole[]   @relation("UserBranchScopes")
  changeRequests      ChangeRequest[]      @relation("ChangeRequestRequester")
  reviewedRequests    ChangeRequest[]      @relation("ChangeRequestReviewer")

  @@index([personId])
  @@map("app_users")
}

model RolePermission {
  roleCode       String     @map("role_code") @db.VarChar(40)
  permissionCode String     @map("permission_code") @db.VarChar(80)
  role           Role       @relation(fields: [roleCode], references: [code], onDelete: Cascade)
  permission     Permission @relation(fields: [permissionCode], references: [code], onDelete: Cascade)

  @@id([roleCode, permissionCode])
  @@map("role_permissions")
}

model UserRole {
  userId   String @map("user_id") @db.Uuid
  roleCode String @map("role_code") @db.VarChar(40)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role   @relation(fields: [roleCode], references: [code], onDelete: Cascade)

  @@id([userId, roleCode])
  @@map("user_roles")
}

enum BranchStatus {
  ACTIVE
  ARCHIVED

  @@map("branch_status")
}

enum CalendarType {
  SOLAR
  LUNAR

  @@map("calendar_type")
}

enum Gender {
  MALE
  FEMALE

  @@map("gender")
}

enum LifeStatus {
  LIVING
  DECEASED

  @@map("life_status")
}

enum ParentRole {
  FATHER
  MOTHER

  @@map("parent_role")
}

enum ParentRelationType {
  BIOLOGICAL
  ADOPTIVE

  @@map("parent_relation_type")
}

enum MarriageStatus {
  ACTIVE
  DIVORCED
  WIDOWED
  ENDED
  UNKNOWN

  @@map("marriage_status")
}

enum LeadershipTransferType {
  INITIAL
  MANUAL
  AUTO_DEATH
  AUTO_SENIOR_SON

  @@map("leadership_transfer_type")
}

enum RecurrenceType {
  ANNUAL_LUNAR
  ANNUAL_SOLAR

  @@map("recurrence_type")
}

enum NotificationScope {
  BRANCH
  CLAN
  CUSTOM

  @@map("notification_scope")
}

enum EventType {
  DEATH_ANNIVERSARY
  ANCESTOR_ANNIVERSARY
  CLAN_MEETING
  GOOD_NEWS
  SAD_NEWS
  OTHER

  @@map("event_type")
}

enum EventSourceType {
  AUTO_ANNIVERSARY
  MANUAL

  @@map("event_source_type")
}

enum EventStatus {
  DRAFT
  PUBLISHED
  COMPLETED
  CANCELLED

  @@map("event_status")
}

enum EventVisibility {
  CLAN
  BRANCH

  @@map("event_visibility")
}

enum NotificationChannel {
  IN_APP
  EMAIL

  @@map("notification_channel")
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED

  @@map("notification_status")
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  HIDDEN

  @@map("content_status")
}

enum ContentVisibility {
  PUBLIC
  MEMBERS
  BRANCH
  LEADERSHIP

  @@map("content_visibility")
}

enum MediaType {
  IMAGE
  DOCUMENT
  OTHER

  @@map("media_type")
}

model Clan {
  id                    String   @id @default(uuid()) @db.Uuid
  singletonKey          Boolean  @default(true) @map("singleton_key")
  name                  String   @default("Dòng họ Nguyễn Trí") @db.VarChar(180)
  description           String?
  history               String?
  founderPersonId       String?  @map("founder_person_id") @db.Uuid
  logoUrl               String?  @map("logo_url")
  bannerUrl             String?  @map("banner_url")
  ancestralHouseName    String?  @map("ancestral_house_name") @db.VarChar(180)
  ancestralHouseAddress String?  @map("ancestral_house_address")
  contactInformation    String?  @map("contact_information")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  founderPerson        Person?               @relation("ClanFounder", fields: [founderPersonId], references: [id], onDelete: SetNull)
  branches             Branch[]              @relation("ClanBranches")
  persons              Person[]              @relation("ClanPersons")
  parentChildRelations ParentChildRelation[] @relation("ClanParentChild")
  marriages            Marriage[]            @relation("ClanMarriages")
  events               Event[]               @relation("ClanEvents")
  posts                Post[]                @relation("ClanPosts")
  albums               Album[]               @relation("ClanAlbums")

  @@unique([singletonKey])
  @@index([founderPersonId])
  @@map("clans")
}

model Branch {
  id             String       @id @default(uuid()) @db.Uuid
  clanId         String       @map("clan_id") @db.Uuid
  parentBranchId String?      @map("parent_branch_id") @db.Uuid
  name           String       @db.VarChar(180)
  type           String       @default("Chi") @db.VarChar(80)
  description    String?
  headPersonId   String?      @map("head_person_id") @db.Uuid
  displayOrder   Int          @default(0) @map("display_order")
  status         BranchStatus @default(ACTIVE)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  clan              Clan                      @relation("ClanBranches", fields: [clanId], references: [id], onDelete: Cascade)
  parent            Branch?                   @relation("BranchTree", fields: [parentBranchId], references: [id], onDelete: Restrict)
  children          Branch[]                  @relation("BranchTree")
  headPerson        Person?                   @relation("BranchHead", fields: [headPersonId], references: [id], onDelete: Restrict)
  persons           Person[]                  @relation("BranchPersons")
  leadershipHistory BranchLeadershipHistory[] @relation("BranchLeadership")
  scopedAnniversaries DeathAnniversary[]      @relation("BranchScopedAnniversaries")
  events            Event[]                   @relation("BranchEvents")
  posts             Post[]                    @relation("BranchPosts")
  albums            Album[]                   @relation("BranchAlbums")
  scopedRoles       BranchScopedRole[]        @relation("BranchScopedRoles")

  @@index([clanId])
  @@index([parentBranchId])
  @@index([headPersonId])
  @@index([status])
  @@index([displayOrder])
  @@map("branches")
}

model Person {
  id               String  @id @default(uuid()) @db.Uuid
  clanId           String  @map("clan_id") @db.Uuid
  branchId         String? @map("branch_id") @db.Uuid
  fullName         String  @map("full_name") @db.VarChar(180)
  commonName       String? @map("common_name") @db.VarChar(180)
  gender           Gender
  isClanMember     Boolean @default(true) @map("is_clan_member")
  avatarUrl        String? @map("avatar_url")
  generationNumber Int?    @map("generation_number")
  displayOrder     Int     @default(0) @map("display_order")

  birthDateSource       CalendarType? @map("birth_date_source")
  birthSolarDate        DateTime?     @map("birth_solar_date") @db.Date
  birthLunarYear        Int?          @map("birth_lunar_year") @db.SmallInt
  birthLunarMonth       Int?          @map("birth_lunar_month") @db.SmallInt
  birthLunarDay         Int?          @map("birth_lunar_day") @db.SmallInt
  birthLunarIsLeapMonth Boolean       @default(false) @map("birth_lunar_is_leap_month")

  lifeStatus            LifeStatus    @default(LIVING) @map("life_status")
  deathDateSource       CalendarType? @map("death_date_source")
  deathSolarDate        DateTime?     @map("death_solar_date") @db.Date
  deathLunarYear        Int?          @map("death_lunar_year") @db.SmallInt
  deathLunarMonth       Int?          @map("death_lunar_month") @db.SmallInt
  deathLunarDay         Int?          @map("death_lunar_day") @db.SmallInt
  deathLunarIsLeapMonth Boolean       @default(false) @map("death_lunar_is_leap_month")

  deathAnniversaryCalendar    CalendarType? @map("death_anniversary_calendar")
  deathAnniversaryMonth       Int?          @map("death_anniversary_month") @db.SmallInt
  deathAnniversaryDay         Int?          @map("death_anniversary_day") @db.SmallInt
  deathAnniversaryIsLeapMonth Boolean       @default(false) @map("death_anniversary_is_leap_month")

  burialPlace   String? @map("burial_place")
  burialMapUrl  String? @map("burial_map_url")
  graveImageUrl String? @map("grave_image_url")
  deathNote     String? @map("death_note")

  biography       String?
  hometown        String?  @db.VarChar(180)
  currentLocation String?  @map("current_location") @db.VarChar(180)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  clan                    Clan                      @relation("ClanPersons", fields: [clanId], references: [id], onDelete: Cascade)
  branch                  Branch?                   @relation("BranchPersons", fields: [branchId], references: [id], onDelete: SetNull)
  foundedClans            Clan[]                    @relation("ClanFounder")
  headedBranches          Branch[]                  @relation("BranchHead")
  parentRelations         ParentChildRelation[]     @relation("ParentRelations")
  childRelations          ParentChildRelation[]     @relation("ChildRelations")
  husbandMarriages        Marriage[]                @relation("HusbandMarriages")
  wifeMarriages           Marriage[]                @relation("WifeMarriages")
  leadershipAsPredecessor BranchLeadershipHistory[] @relation("LeadershipPredecessor")
  leadershipAsSuccessor   BranchLeadershipHistory[] @relation("LeadershipSuccessor")
  deathAnniversaries      DeathAnniversary[]        @relation("PersonAnniversaries")
  userAccounts            User[]                    @relation("PersonUserAccounts")
  media                   Media[]                   @relation("PersonMedia")

  @@index([clanId])
  @@index([branchId])
  @@index([fullName])
  @@index([generationNumber])
  @@index([gender])
  @@index([lifeStatus])
  @@index([birthSolarDate])
  @@index([deathSolarDate])
  @@map("persons")
}

model ParentChildRelation {
  id             String             @id @default(uuid()) @db.Uuid
  clanId         String             @map("clan_id") @db.Uuid
  parentPersonId String             @map("parent_person_id") @db.Uuid
  childPersonId  String             @map("child_person_id") @db.Uuid
  parentRole     ParentRole         @map("parent_role")
  relationType   ParentRelationType @default(BIOLOGICAL) @map("relation_type")
  displayOrder   Int                @default(0) @map("display_order")
  note           String?
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  clan   Clan   @relation("ClanParentChild", fields: [clanId], references: [id], onDelete: Cascade)
  parent Person @relation("ParentRelations", fields: [parentPersonId], references: [id], onDelete: Restrict)
  child  Person @relation("ChildRelations", fields: [childPersonId], references: [id], onDelete: Restrict)

  @@unique([parentPersonId, childPersonId, relationType])
  @@unique([childPersonId, parentRole, relationType])
  @@index([parentPersonId])
  @@index([childPersonId])
  @@index([clanId])
  @@index([relationType])
  @@map("parent_child_relations")
}

model Marriage {
  id               String         @id @default(uuid()) @db.Uuid
  clanId           String         @map("clan_id") @db.Uuid
  husbandPersonId  String         @map("husband_person_id") @db.Uuid
  wifePersonId     String         @map("wife_person_id") @db.Uuid
  status           MarriageStatus @default(ACTIVE)
  marriedSolarDate DateTime?      @map("married_solar_date") @db.Date
  endedSolarDate   DateTime?      @map("ended_solar_date") @db.Date
  note             String?
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  clan    Clan   @relation("ClanMarriages", fields: [clanId], references: [id], onDelete: Cascade)
  husband Person @relation("HusbandMarriages", fields: [husbandPersonId], references: [id], onDelete: Restrict)
  wife    Person @relation("WifeMarriages", fields: [wifePersonId], references: [id], onDelete: Restrict)

  @@unique([husbandPersonId, wifePersonId])
  @@index([clanId])
  @@index([husbandPersonId])
  @@index([wifePersonId])
  @@index([status])
  @@map("marriages")
}

model BranchLeadershipHistory {
  id                  String                 @id @default(uuid()) @db.Uuid
  branchId            String                 @map("branch_id") @db.Uuid
  predecessorPersonId String?                @map("predecessor_person_id") @db.Uuid
  successorPersonId   String?                @map("successor_person_id") @db.Uuid
  transferDate        DateTime               @default(now()) @map("transfer_date") @db.Date
  transferType        LeadershipTransferType @map("transfer_type")
  reason              String?
  note                String?
  createdByUserId     String?                @map("created_by_user_id") @db.Uuid
  createdAt           DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)

  branch      Branch  @relation("BranchLeadership", fields: [branchId], references: [id], onDelete: Cascade)
  predecessor Person? @relation("LeadershipPredecessor", fields: [predecessorPersonId], references: [id], onDelete: Restrict)
  successor   Person? @relation("LeadershipSuccessor", fields: [successorPersonId], references: [id], onDelete: Restrict)

  @@index([branchId, transferDate, createdAt])
  @@index([predecessorPersonId])
  @@index([successorPersonId])
  @@map("branch_leadership_history")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  action       String   @db.VarChar(120)
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  employeeCode String?  @map("employee_code") @db.VarChar(40)
  success      Boolean
  important    Boolean  @default(false)
  entityType   String?  @map("entity_type") @db.VarChar(80)
  entityId     String?  @map("entity_id") @db.VarChar(80)
  beforeData   Json?    @map("before_data")
  afterData    Json?    @map("after_data")
  reason       String?
  ipAddress    String?  @map("ip_address") @db.VarChar(80)
  userAgent    String?  @map("user_agent")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

enum ChangeRequestType {
  CREATE
  UPDATE
  DELETE

  @@map("change_request_type")
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("change_request_status")
}

model BranchScopedRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleCode  String   @map("role_code") @db.VarChar(40)
  branchId  String   @map("branch_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user   User   @relation("UserBranchScopes", fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation("BranchScopedRoles", fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, roleCode, branchId])
  @@index([userId])
  @@index([branchId])
  @@map("branch_scoped_roles")
}

model ChangeRequest {
  id           String              @id @default(uuid()) @db.Uuid
  requestedBy  String              @map("requested_by") @db.Uuid
  entityType   String              @map("entity_type") @db.VarChar(80)
  entityId     String?             @map("entity_id") @db.VarChar(80)
  requestType  ChangeRequestType   @map("request_type")
  proposedData Json                @map("proposed_data")
  reason       String?
  status       ChangeRequestStatus @default(PENDING)
  reviewedBy   String?             @map("reviewed_by") @db.Uuid
  reviewedAt   DateTime?           @map("reviewed_at") @db.Timestamptz(6)
  reviewNote   String?             @map("review_note")
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  requester User  @relation("ChangeRequestRequester", fields: [requestedBy], references: [id], onDelete: Cascade)
  reviewer  User? @relation("ChangeRequestReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([requestedBy])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("change_requests")
}

model DeathAnniversary {
  id                String            @id @default(uuid()) @db.Uuid
  personId          String            @map("person_id") @db.Uuid
  lunarDay          Int               @map("lunar_day") @db.SmallInt
  lunarMonth        Int               @map("lunar_month") @db.SmallInt
  isLeapMonth       Boolean           @default(false) @map("is_leap_month")
  solarDateCache    DateTime?         @map("solar_date_cache") @db.Date
  solarDateCacheYear Int?             @map("solar_date_cache_year") @db.SmallInt
  recurrenceType    RecurrenceType    @default(ANNUAL_LUNAR) @map("recurrence_type")
  branchScopeId     String?           @map("branch_scope_id") @db.Uuid
  notificationScope NotificationScope @default(BRANCH) @map("notification_scope")
  notifyBeforeDays  Int               @default(7) @map("notify_before_days") @db.SmallInt
  ceremonyNote      String?           @map("ceremony_note")
  active            Boolean           @default(true)
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  person      Person  @relation("PersonAnniversaries", fields: [personId], references: [id], onDelete: Cascade)
  branchScope Branch? @relation("BranchScopedAnniversaries", fields: [branchScopeId], references: [id], onDelete: SetNull)

  @@index([personId])
  @@index([branchScopeId])
  @@index([active])
  @@index([lunarMonth, lunarDay])
  @@map("death_anniversaries")
}

model Event {
  id            String          @id @default(uuid()) @db.Uuid
  clanId        String          @map("clan_id") @db.Uuid
  branchId      String?         @map("branch_id") @db.Uuid
  sourceType    EventSourceType @default(MANUAL) @map("source_type")
  sourceId      String?         @map("source_id") @db.Uuid
  title         String          @db.VarChar(200)
  eventType     EventType       @map("event_type")
  description   String?
  calendarType  CalendarType    @default(SOLAR) @map("calendar_type")
  lunarDay      Int?            @map("lunar_day") @db.SmallInt
  lunarMonth    Int?            @map("lunar_month") @db.SmallInt
  isLeapMonth   Boolean         @default(false) @map("is_leap_month")
  startDatetime DateTime        @map("start_datetime") @db.Timestamptz(6)
  endDatetime   DateTime?       @map("end_datetime") @db.Timestamptz(6)
  location      String?
  visibilityScope EventVisibility @default(CLAN) @map("visibility_scope")
  status        EventStatus     @default(PUBLISHED)
  createdBy     String?         @map("created_by") @db.Uuid
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  clan          Clan           @relation("ClanEvents", fields: [clanId], references: [id], onDelete: Cascade)
  branch        Branch?        @relation("BranchEvents", fields: [branchId], references: [id], onDelete: SetNull)
  notifications Notification[] @relation("EventNotifications")
  posts         Post[]         @relation("EventPosts")
  albums        Album[]        @relation("EventAlbums")
  media         Media[]        @relation("EventMedia")

  @@unique([sourceType, sourceId, startDatetime])
  @@index([clanId])
  @@index([branchId])
  @@index([startDatetime])
  @@index([status])
  @@index([eventType])
  @@map("events")
}

model Notification {
  id          String              @id @default(uuid()) @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  eventId     String?             @map("event_id") @db.Uuid
  channel     NotificationChannel @default(IN_APP)
  reminderKey String              @map("reminder_key") @db.VarChar(200)
  title       String              @db.VarChar(200)
  content     String?
  readAt      DateTime?           @map("read_at") @db.Timestamptz(6)
  sentAt      DateTime?           @map("sent_at") @db.Timestamptz(6)
  status      NotificationStatus  @default(PENDING)
  errorMessage String?            @map("error_message")
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  user  User   @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation("EventNotifications", fields: [eventId], references: [id], onDelete: SetNull)

  @@unique([reminderKey])
  @@index([userId])
  @@index([userId, readAt])
  @@index([eventId])
  @@index([status])
  @@map("notifications")
}

model NotificationSetting {
  userId       String   @id @map("user_id") @db.Uuid
  inAppEnabled Boolean  @default(true) @map("in_app_enabled")
  emailEnabled Boolean  @default(false) @map("email_enabled")
  email        String?  @db.VarChar(200)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation("UserNotificationSetting", fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

model Category {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(160)
  slug         String   @unique @db.VarChar(180)
  description  String?
  displayOrder Int      @default(0) @map("display_order")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  posts Post[] @relation("CategoryPosts")

  @@index([active])
  @@index([displayOrder])
  @@map("categories")
}

model Post {
  id              String            @id @default(uuid()) @db.Uuid
  clanId          String            @map("clan_id") @db.Uuid
  branchId        String?           @map("branch_id") @db.Uuid
  categoryId      String?           @map("category_id") @db.Uuid
  relatedEventId  String?           @map("related_event_id") @db.Uuid
  title           String            @db.VarChar(220)
  slug            String            @unique @db.VarChar(240)
  summary         String?
  content         String?
  thumbnailUrl    String?           @map("thumbnail_url")
  visibilityScope ContentVisibility @default(PUBLIC) @map("visibility_scope")
  isPinned        Boolean           @default(false) @map("is_pinned")
  status          ContentStatus     @default(DRAFT)
  authorId        String?           @map("author_id") @db.Uuid
  publishedAt     DateTime?         @map("published_at") @db.Timestamptz(6)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  clan         Clan      @relation("ClanPosts", fields: [clanId], references: [id], onDelete: Cascade)
  branch       Branch?   @relation("BranchPosts", fields: [branchId], references: [id], onDelete: SetNull)
  category     Category? @relation("CategoryPosts", fields: [categoryId], references: [id], onDelete: SetNull)
  relatedEvent Event?    @relation("EventPosts", fields: [relatedEventId], references: [id], onDelete: SetNull)
  author       User?     @relation("UserPosts", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([clanId])
  @@index([branchId])
  @@index([categoryId])
  @@index([relatedEventId])
  @@index([status])
  @@index([visibilityScope])
  @@index([isPinned])
  @@index([publishedAt])
  @@map("posts")
}

model Album {
  id              String            @id @default(uuid()) @db.Uuid
  clanId          String            @map("clan_id") @db.Uuid
  branchId        String?           @map("branch_id") @db.Uuid
  relatedEventId  String?           @map("related_event_id") @db.Uuid
  title           String            @db.VarChar(220)
  slug            String            @unique @db.VarChar(240)
  description     String?
  coverMediaId    String?           @map("cover_media_id") @db.Uuid
  visibilityScope ContentVisibility @default(PUBLIC) @map("visibility_scope")
  status          ContentStatus     @default(DRAFT)
  createdBy       String?           @map("created_by") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  clan         Clan    @relation("ClanAlbums", fields: [clanId], references: [id], onDelete: Cascade)
  branch       Branch? @relation("BranchAlbums", fields: [branchId], references: [id], onDelete: SetNull)
  relatedEvent Event?  @relation("EventAlbums", fields: [relatedEventId], references: [id], onDelete: SetNull)
  creator      User?   @relation("UserAlbums", fields: [createdBy], references: [id], onDelete: SetNull)
  cover        Media?  @relation("AlbumCover", fields: [coverMediaId], references: [id], onDelete: SetNull)
  media        Media[] @relation("AlbumMedia")

  @@index([clanId])
  @@index([branchId])
  @@index([relatedEventId])
  @@index([status])
  @@index([visibilityScope])
  @@map("albums")
}

model Media {
  id         String    @id @default(uuid()) @db.Uuid
  albumId    String?   @map("album_id") @db.Uuid
  personId   String?   @map("person_id") @db.Uuid
  eventId    String?   @map("event_id") @db.Uuid
  fileType   MediaType @default(IMAGE) @map("file_type")
  fileUrl    String    @map("file_url")
  fileName   String    @map("file_name") @db.VarChar(255)
  mimeType   String    @map("mime_type") @db.VarChar(180)
  fileSize   Int       @map("file_size")
  caption    String?
  uploadedBy String?   @map("uploaded_by") @db.Uuid
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  album       Album?  @relation("AlbumMedia", fields: [albumId], references: [id], onDelete: SetNull)
  albumCovers Album[] @relation("AlbumCover")
  person      Person? @relation("PersonMedia", fields: [personId], references: [id], onDelete: SetNull)
  event       Event?  @relation("EventMedia", fields: [eventId], references: [id], onDelete: SetNull)
  uploader    User?   @relation("UserMedia", fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([albumId])
  @@index([personId])
  @@index([eventId])
  @@index([fileType])
  @@index([deletedAt])
  @@map("media")
}

model PageContent {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(80)
  title     String   @db.VarChar(200)
  content   String?
  updatedBy String?  @map("updated_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  editor User? @relation("UserPages", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@map("page_content")
}
