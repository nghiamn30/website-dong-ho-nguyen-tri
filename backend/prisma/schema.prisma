generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Permission {
  code  String           @id @db.VarChar(80)
  name  String           @db.VarChar(160)
  roles RolePermission[]

  @@map("permissions")
}

model Role {
  code        String           @id @db.VarChar(40)
  name        String           @db.VarChar(160)
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  employeeCode String     @unique @map("employee_code") @db.VarChar(40)
  name         String     @db.VarChar(160)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  roles        UserRole[]

  @@map("app_users")
}

model RolePermission {
  roleCode       String     @map("role_code") @db.VarChar(40)
  permissionCode String     @map("permission_code") @db.VarChar(80)
  role           Role       @relation(fields: [roleCode], references: [code], onDelete: Cascade)
  permission     Permission @relation(fields: [permissionCode], references: [code], onDelete: Cascade)

  @@id([roleCode, permissionCode])
  @@map("role_permissions")
}

model UserRole {
  userId   String @map("user_id") @db.Uuid
  roleCode String @map("role_code") @db.VarChar(40)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role   @relation(fields: [roleCode], references: [code], onDelete: Cascade)

  @@id([userId, roleCode])
  @@map("user_roles")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  action       String   @db.VarChar(120)
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  employeeCode String?  @map("employee_code") @db.VarChar(40)
  success      Boolean
  important    Boolean  @default(false)
  ipAddress    String?  @map("ip_address") @db.VarChar(80)
  userAgent    String?  @map("user_agent")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
