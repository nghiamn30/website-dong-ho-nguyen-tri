NODE_ENV=development
PORT=3001
FRONTEND_ORIGIN=http://localhost:3000
JWT_SECRET=change-this-local-secret
JWT_EXPIRES_IN=8h

# Keep DB_ENABLED=false for quick UI/auth local smoke tests without a database.
DB_ENABLED=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dong_ho_nguyen_tri
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=dong_ho_nguyen_tri

AUDIT_LOG_MEMORY_LIMIT=2000

# Optional production bootstrap. Use only when creating the first admin.
BOOTSTRAP_ADMIN_EMPLOYEE_CODE=ADMIN001
BOOTSTRAP_ADMIN_NAME=Quản trị viên hệ thống
BOOTSTRAP_ADMIN_PASSWORD=
